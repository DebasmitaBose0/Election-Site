# Flask Configuration
SECRET_KEY=your-secret-key-here
FLASK_ENV=production
FLASK_DEBUG=0
PORT=8080

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key-here
PREFERRED_GEMINI_MODEL=models/gemini-1.5-flash-8b

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_REDIRECT_URI=https://your-app-name-xxxxxx.run.app/auth/callback

# Google Civic Information API
GOOGLE_CIVIC_API_KEY=your-civic-api-key-here

# Google Maps API
GOOGLE_MAPS_API_KEY=your-maps-api-key-here

# Google YouTube API
GOOGLE_YOUTUBE_API_KEY=your-youtube-api-key-here

# Rate Limiting
RATE_LIMIT=30

# External APIs
GNEWS_API_KEY=your-gnews-api-key-here
GROQ_API_KEY=your-groq-api-key-here (fallback)
